PORT=5000
MONGO_URI=mongodb://localhost:27017/salonpro
JWT_SECRET=your_jwt_signing_secret_for_tenants
JWT_EXPIRE=7d
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# Email Transporter Setup (Gmail Default)
GMAIL_USER=your_gmail_username@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_specific_password

# Custom SMTP Setup (e.g. Brevo)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# SuperAdmin Credentials
ADMIN_EMAIL=admin@salonpro.com
ADMIN_PASSWORD=admin123
ADMIN_JWT_SECRET=superadmin_secret_key_change_before_launch

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_signature_secret
